% use with
% \begin{gg_box}[width=7cm, height=3cm, valign=center]
\NewEnviron{gg_box}[1][]{%
  \begin{tcolorbox}[colback=black!5, colframe=white!80!, breakable, #1]
    \BODY
  \end{tcolorbox}%
}

% Define a tight box style as the above but inline
\newtcbox{\ggcell}[1][]{%
  on line,
  boxsep=0pt,
  left=4pt, right=4pt, top=4pt, bottom=4pt,
  colback=black!5, colframe=white!80!, breakable, #1
}

\definecolor{codecolor}{RGB}{255, 185, 83}
