% use with
% \begin{gg_box}[width=7cm, height=3cm, valign=center]
\NewEnviron{gg_box}[1][]{%
  \begin{tcolorbox}[colback=black!5, colframe=white!80!, breakable, #1]
    \BODY
  \end{tcolorbox}%
}

